APP_NAME="NexusOS"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexusos
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=cookie
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:8000
SANCTUM_ENCRYPTION_KEY=

VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=http://localhost:8000

# Biometric Integration
BIOMETRIC_PROVIDER=zkteco
BIOMETRIC_HOST=127.0.0.1
BIOMETRIC_PORT=4370

# WhatsApp & SMS Gateway
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
SMS_GATEWAY_API_KEY=
SMS_GATEWAY_PROVIDER=gupshup

# Accounting Integration
TALLY_API_URL=
ZOHO_API_KEY=
ZOHO_ORG_ID=

# Banking Integration
BANK_API_KEY=
BANK_API_SECRET=
BANK_PROVIDER=hdfc

# Feature Flags
FEATURE_BIOMETRIC_SYNC=true
FEATURE_WHATSAPP_NOTIFICATIONS=true
FEATURE_ATTENDANCE_ANOMALY_DETECTION=false
FEATURE_LEAVE_FORECASTING=false
